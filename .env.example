# =============================================================================
# DocScribe — environment variables
# Copy this file to .env and fill in the values before running docker compose.
# =============================================================================

# Shared secret — must be IDENTICAL in apps/web and apps/api (min 32 chars)
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string

# Google OAuth credentials (from Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI API keys
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# apps/api — FastAPI
# In docker-compose the DB URL is injected automatically.
# Uncomment and fill for local development outside docker-compose.
# DOCSCRIBE_DB_URL=postgresql://postgres:postgres@localhost:5432/docscribe

# Optional overrides (defaults shown)
# CORS_ORIGINS=["http://localhost:3000"]
# MAX_HISTORY_MESSAGES=50
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# WHISPER_MODEL=whisper-large-v3-turbo

# -----------------------------------------------------------------------------
# apps/web — Next.js
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001

# Same DB as above — used by @auth/pg-adapter to store NextAuth sessions
# NEXTAUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docscribe

# Internal URL for server-side Next.js → FastAPI calls (inside docker network)
# API_INTERNAL_URL=http://api:8001
